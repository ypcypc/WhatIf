# =============================================================================
# WhatIf - LLM Provider API Keys
# =============================================================================
# 复制此文件为 .env 并填入你的 API Key：
#   cp .env.example .env
#
# 你只需要填写 llm_config.yaml 中使用的 Provider 对应的 Key。
# 默认配置使用 Qwen (DashScope)，如需切换请修改 llm_config.yaml。
# =============================================================================

# --- Qwen / DashScope（默认 Provider，推荐）---
# 申请地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# --- Google Gemini（可选）---
# 申请地址: https://aistudio.google.com/apikey
# 注：GEMINI_API_KEY 和 GOOGLE_API_KEY 均可识别
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenAI（可选）---
# 申请地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Anthropic（可选）---
# 申请地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- StepFun / 阶跃星辰（可选）---
# 申请地址: https://platform.stepfun.com/
STEPFUN_API_KEY=your_stepfun_api_key_here

# --- xAI / Grok（可选）---
# 申请地址: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# --- Volcengine / 豆包（可选）---
# 申请地址: https://console.volcengine.com/
VOLCENGINE_API_KEY=your_volcengine_api_key_here
